{% doc %}
  @prompt
    Add custom CSS to apply the font "Kenao" (sans-serif fallback) to the custom footer section titles/headings. The font is already uploaded to the store. Use font-family: "Kenao", sans-serif !important; targeting the footer title elements.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-custom-footer-css-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  {% if block.settings.apply_to_all_footers %}
    footer h2,
    footer h3,
    footer h4,
    footer h5,
    footer h6,
    footer .footer-block__heading,
    footer .footer__heading,
    .footer h2,
    .footer h3,
    .footer h4,
    .footer h5,
    .footer h6,
    .footer .footer-block__heading,
    .footer .footer__heading {
      font-family: "Kenao", sans-serif !important;
    }
  {% else %}
    {{ block.settings.custom_selector }} {
      font-family: "Kenao", sans-serif !important;
    }
  {% endif %}
{% endstyle %}

<div class="ai-custom-footer-css-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
</div>

{% schema %}
{
  "name": "Custom footer font CSS",
  "settings": [
    {
      "type": "header",
      "content": "Font settings"
    },
    {
      "type": "paragraph",
      "content": "This block applies the Kenao font to footer headings and titles."
    },
    {
      "type": "checkbox",
      "id": "apply_to_all_footers",
      "label": "Apply to all footer headings",
      "default": true
    },
    {
      "type": "text",
      "id": "custom_selector",
      "label": "Custom CSS selector",
      "default": ".footer h2, .footer h3, .footer h4"
    }
  ],
  "presets": [
    {
      "name": "Custom footer font CSS"
    }
  ]
}
{% endschema %}
